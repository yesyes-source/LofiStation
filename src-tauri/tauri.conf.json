{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lofi-station",
  "version": "0.1.1",
  "identifier": "com.lofi.station",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LofiStation",
        "width": 880,
        "height": 550,
        "resizable": true,
        "minWidth": 650,
        "minHeight": 450,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
